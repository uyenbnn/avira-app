{
  "name": "avira-integration-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Integration tests for Avira services using Node.js and Axios",
  "scripts": {
    "test:mvp:docker": "node tests/mvp-tenant-creation-shared-realm.integration.js --env .env.docker && node tests/mvp-application-creation-under-tenant.integration.js --env .env.docker && node tests/mvp-iam-shared-realm-init-provision.integration.js --env .env.docker && node tests/mvp-app-token-exchange-shape.integration.js --env .env.docker",
    "test:mvp:kong": "node tests/mvp-tenant-creation-shared-realm.integration.js --env .env.kong && node tests/mvp-application-creation-under-tenant.integration.js --env .env.kong && node tests/mvp-iam-shared-realm-init-provision.integration.js --env .env.kong && node tests/mvp-app-token-exchange-shape.integration.js --env .env.kong",
    "test:mvp:k3s": "node tests/mvp-tenant-creation-shared-realm.integration.js --env .env.k3s && node tests/mvp-application-creation-under-tenant.integration.js --env .env.k3s && node tests/mvp-iam-shared-realm-init-provision.integration.js --env .env.k3s && node tests/mvp-app-token-exchange-shape.integration.js --env .env.k3s",
    "test:iam:docker": "node tests/iam-service.integration.js --env .env.docker",
    "test:iam:kong": "node tests/iam-service.integration.js --env .env.kong",
    "test:iam:k3s": "node tests/iam-service.integration.js --env .env.k3s",
    "test:keycloak:init:docker": "node tests/keycloak-realms-auto-created.integration.js --env .env.docker && node tests/keycloak-clients-provisioned.integration.js --env .env.docker && node tests/keycloak-default-users-provisioned.integration.js --env .env.docker",
    "test:keycloak:init:kong": "node tests/keycloak-realms-auto-created.integration.js --env .env.kong && node tests/keycloak-clients-provisioned.integration.js --env .env.kong && node tests/keycloak-default-users-provisioned.integration.js --env .env.kong",
    "test:keycloak:init:k3s": "node tests/keycloak-realms-auto-created.integration.js --env .env.k3s && node tests/keycloak-clients-provisioned.integration.js --env .env.k3s && node tests/keycloak-default-users-provisioned.integration.js --env .env.k3s"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "dotenv": "^16.6.1",
    "uuid": "^11.1.0"
  }
}

