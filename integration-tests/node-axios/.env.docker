# Local docker/spring-run defaults
AUTH_BASE_URL=http://localhost:10001/api
PROJECT_BASE_URL=http://localhost:10004/api
INIT_BASE_URL=http://localhost:10000/api
USER_BASE_URL=

# Registration + login credentials (a unique username is generated per run)
TEST_USER_PASSWORD=Test123!

# Optional admin checks
ADMIN_EMAIL=admin@avira.local
